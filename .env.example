# Google Pub/Sub
PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/YOUR_TOPIC
PUBSUB_SUBSCRIPTION=projects/YOUR_PROJECT/subscriptions/YOUR_SUB

# Google service account JSON file (ignored by git)
GOOGLE_APPLICATION_CREDENTIALS="executive-agent.json"

# PostgreSQL database URL
DATABASE_URL="postgresql+asyncpg://user:password@host:5432/dbname"

# JWT secret key (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256

# Google OAuth client secrets JSON file (ignored by git)
GOOGLE_OAUTH_CLIENT_SECRETS="onebox_oauth.json"

# OAuth redirect URIs
OAUTH_REDIRECT_URI=https://your-domain.com/agent/oauth/callback
FRONTEND_OAUTH_CALLBACK_URI=https://your-domain.com/mail/inbox
